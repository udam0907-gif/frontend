# ─── Docker Compose 환경 변수 ─────────────────────────────────────────────────
# 이 파일을 .env 로 복사 후 값을 채워주세요:  cp .env.example .env

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=password
POSTGRES_DB=rnd_expense_db
POSTGRES_PORT=5432

# Backend API
BACKEND_PORT=8000

# Frontend
FRONTEND_PORT=3001
# 브라우저에서 접근하는 백엔드 URL (다른 서버에 배포 시 IP/도메인으로 변경)
NEXT_PUBLIC_API_URL=http://localhost:8000
