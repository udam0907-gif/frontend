# Application
APP_NAME="R&D 비용 집행 관리 시스템"
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-in-production-minimum-32-chars
API_V1_PREFIX=/api/v1
ALLOWED_ORIGINS_STR=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000

# Database (Docker Compose 사용 시 host는 postgres, 로컬 직접 실행 시 localhost)
DATABASE_URL=postgresql+asyncpg://postgres:password@postgres:5432/rnd_expense_db
DATABASE_POOL_SIZE=10
DATABASE_MAX_OVERFLOW=20

# Anthropic / Claude  →  https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=your-anthropic-api-key-here
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-6
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.1
PROMPT_CACHE_ENABLED=true

# Embedding (local = API 키 불필요)
EMBEDDING_PROVIDER=local
OPENAI_API_KEY=
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# Korea Law API  →  https://law.go.kr 에서 가입 후 이메일로 발급
LAW_API_OC=your-law-api-email

# Storage
STORAGE_BACKEND=local
STORAGE_BASE_PATH=./storage
STORAGE_TEMPLATES_PATH=./storage/templates
STORAGE_DOCUMENTS_PATH=./storage/documents
STORAGE_MANUALS_PATH=./storage/manuals
STORAGE_EXPORTS_PATH=./storage/exports

# RAG
RAG_CHUNK_SIZE=800
RAG_CHUNK_OVERLAP=100
RAG_MAX_CHUNKS=5
RAG_MIN_CONFIDENCE=0.75

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
